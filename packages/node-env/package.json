{
  "name": "@pubfunc/node-env",
  "version": "1.0.0",
  "description": "Type-safe process.env wrapper",
  "repository": {
    "type": "git",
    "url": "https://github.com/pubfunc/node-utils.git"
  },
  "author": "Pubfunc",
  "license": "MIT",
  "homepage": "https://github.com/pubfunc/node-utils",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=18"
  }
}
